# Server Configuration
PORT=5000

# Database Configuration
# Local: mongodb://127.0.0.1:27017/ai_web_app
# Atlas: mongodb+srv://<username>:<password>@cluster0.mongodb.net/ai_web_app?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/ai_web_app

# Security Configuration
